{
  "manifest_version": 3,
  "name": "NoBait v2 - Link Redirect Resolver",
  "version": "0.1.0",
  "description": "Hold-click any link to resolve its final destination URL after redirects.",
  "permissions": ["activeTab", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["tooltip.css"],
      "run_at": "document_idle"
    }
  ]
}
