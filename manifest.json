{
  "manifest_version": 3,
  "name": "NoBait v2 - Link Redirect Resolver",
  "version": "0.11.3",
  "description": "Hold-click any link to resolve redirects and reveal the briefest possible answer to clickbait headlines.",
  "permissions": ["activeTab", "tabs", "storage"],
  "host_permissions": ["https://nobait-proxy.acr197.workers.dev/*", "<all_urls>"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "NoBait v2 — settings",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["tooltip.css"],
      "run_at": "document_idle"
    }
  ]
}