{
  "manifest_version": 3,
  "name": "NoBait v2 - Link Redirect Resolver",
  "version": "0.3.0",
  "description": "Hold-click any link to resolve redirects and reveal the briefest possible answer to clickbait headlines.",
  "permissions": ["activeTab", "tabs"],
  "host_permissions": ["https://nobait-proxy.acr197.workers.dev/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["tooltip.css"],
      "run_at": "document_idle"
    }
  ]
}
